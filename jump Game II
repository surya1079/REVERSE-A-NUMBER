class Solution:
    def jump(self, nums):
        n = len(nums)
        if n <= 1:
            return 0
        jumps = 0
        current_end = 0  # The end of the current jump range
        farthest = 0     # The farthest index we can reach
        for i in range(n - 1):  # We don't need to jump from the last index
            # Update the farthest we can reach from current position
            farthest = max(farthest, i + nums[i])
            # If we've reached the end of current jump range
            if i == current_end:
                jumps += 1
                current_end = farthest
                # Early exit if we can already reach the end
                if current_end >= n - 1:
                    break
        return jumps
