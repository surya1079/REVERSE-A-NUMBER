class Solution:
    def minCostClimbingStairs(self, cost):
        n = len(cost)
        # dp[i] represents the minimum cost to reach step i
        dp = [0] * n
        # Base cases
        dp[0] = cost[0]
        dp[1] = cost[1]
        # Fill dp array
        for i in range(2, n):
            dp[i] = cost[i] + min(dp[i-1], dp[i-2])
        # The top is after the last step, so we can reach it from either last or second last step
        return min(dp[n-1], dp[n-2])
